NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://checkmite:password@127.0.0.1:5432/checkmite

UPLOAD_DIR=uploads
UPLOAD_MAX_IMAGE_MB=20
UPLOAD_MAX_VIDEO_MB=500

MODEL_RUNTIME_URL=http://127.0.0.1:8000
MODEL_RUNTIME_REQUIRED=false
FRONTEND_DIST_DIR=dist

CHECKMITE_MODEL_PATH=./model/best.pt
CHECKMITE_CONF=0.5
CHECKMITE_IMGSZ=640
CHECKMITE_TILE_SIZE=640
CHECKMITE_TILE_OVERLAP=0.5
CHECKMITE_NMS_IOU=0.3
CHECKMITE_VITALITY_TARGET_CLASS=predator
CHECKMITE_VITALITY_MODEL_PATH=./model/vitality/best1.onnx
CHECKMITE_VITALITY_IMGSZ=1280
CHECKMITE_VITALITY_PX_PER_MM=1500
CHECKMITE_VITALITY_REFERENCE_SPEED_MM_SEC=0.025
CHECKMITE_VITALITY_MIN_TRACK_FRAMES=3
CHECKMITE_VITALITY_MOTION_THRESHOLD_PX=2.0
CHECKMITE_VITALITY_MAX_FRAMES=80
CHECKMITE_VITALITY_NORMAL_SPEED_RATIO=3.0
CHECKMITE_VITALITY_NORMAL_SPEED_SCORE=0.60
CHECKMITE_VITALITY_FAST_SPEED_RATIO=6.0
CHECKMITE_VITALITY_FAST_SPEED_SCORE=0.92
CHECKMITE_DENSITY_TARGET_CLASS=predator
CHECKMITE_DENSITY_FRAME_INTERVAL_SECONDS=1
CHECKMITE_DENSITY_COUNT_MULTIPLIER=10
CHECKMITE_DENSITY_MIN_VIDEO_SECONDS=10
CHECKMITE_ANALYSIS_WINDOW_SECONDS=10
CHECKMITE_DENSITY_MAX_FRAMES=0
CHECKMITE_DENSITY_MIN_SHARPNESS=50
CHECKMITE_DENSITY_MIN_BRIGHTNESS=40
CHECKMITE_DENSITY_MAX_BRIGHTNESS=220
